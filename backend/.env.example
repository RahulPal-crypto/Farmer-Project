PORT=5000
NODE_ENV=development
MONGO_URI=your-mongodb-connection-string
JWT_SECRET=your-super-secret-jwt-key

# Comma-separated frontend origins allowed to call this API.
# Production example:
# CLIENT_URL=https://your-frontend-domain.com
CLIENT_URL=http://localhost:5173

# Optional. Use this if your host sits behind a proxy and image URLs need an explicit backend URL.
# API_PUBLIC_URL=https://your-backend-domain.com

# Required in production for persistent product images.
# Local disk uploads are only suitable for development.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required only if Razorpay checkout is enabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
